<!DOCTYPE html>
<html>
<head>
    <title>Users - OSINT Hub</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dark-theme.css">
    <link rel="stylesheet" href="/css/responsive.css">
</head>
<body>
    <%- include('partials/sidebar', { currentPage: 'users' }) %>
    <div class="main-content">
        <%- include('partials/topbar', { pageTitle: '👥 Users Management' }) %>
        <div class="content">
            <div class="card">
                <h3>User List</h3>
                <table>
                    <thead>
                        <tr><th>ID</th><th>Username</th><th>Role</th><th>Created By</th><th>Created At</th></tr>
                    </thead>
                    <tbody>
                        <% if (users && users.length > 0) { %>
                            <% users.forEach(user => { %>
                                <tr>
                                    <td><%= user.id %></td>
                                    <td><%= user.username %></td>
                                    <td><%= user.role %></td>
                                    <td><%= user.created_by || 'System' %></td>
                                    <td><%= user.created_at %></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="5">No users found</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <script src="/js/main.js"></script>
    <script src="/js/theme.js"></script>
</body>
</html>
