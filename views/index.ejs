<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sahil</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root{
    --glass: rgba(255,255,255,0.08);
    --border: rgba(255,255,255,0.14);
    --text: #f5f6fb;
    --text-dim: rgba(245,246,251,0.58);
    --text-faint: rgba(245,246,251,0.38);
    --blue: #64b5ff;
    --green: #38e07a;
  }
  *{box-sizing:border-box; -webkit-tap-highlight-color:transparent;}
  html,body{margin:0;padding:0;}
  body{
    min-height:100vh;
    font-family:-apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Inter', sans-serif;
    color:var(--text);
    display:flex;
    justify-content:center;
    padding:56px 18px;
    background:#0b0d1a;
    overflow-x:hidden;
    position:relative;
  }

  .bg{
    position:fixed;
    inset:0;
    z-index:0;
    overflow:hidden;
    background:linear-gradient(160deg,#0b0d1a 0%, #14152b 45%, #1a1330 100%);
  }
  .orb{
    position:absolute;
    border-radius:50%;
    filter:blur(70px);
    opacity:0.55;
  }
  .orb1{width:380px;height:380px; background:#3d6bff; top:-120px; left:-90px; animation:float1 16s ease-in-out infinite;}
  .orb2{width:340px;height:340px; background:#c14fff; bottom:-100px; right:-80px; animation:float2 18s ease-in-out infinite;}
  .orb3{width:280px;height:280px; background:#ff5fa8; top:40%; left:60%; animation:float3 20s ease-in-out infinite;}
  .orb4{width:240px;height:240px; background:#2fe0c9; bottom:20%; left:-60px; animation:float1 22s ease-in-out infinite reverse;}
  @keyframes float1{0%,100%{transform:translate(0,0);} 50%{transform:translate(40px,50px);}}
  @keyframes float2{0%,100%{transform:translate(0,0);} 50%{transform:translate(-50px,-30px);}}
  @keyframes float3{0%,100%{transform:translate(0,0);} 50%{transform:translate(-30px,40px);}}

  .wrap{
    position:relative;
    z-index:1;
    width:100%;
    max-width:400px;
  }

  .card{
    background:var(--glass);
    border:1px solid var(--border);
    border-radius:28px;
    backdrop-filter:blur(24px) saturate(180%);
    -webkit-backdrop-filter:blur(24px) saturate(180%);
    box-shadow:0 8px 32px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.08);
  }

  .header{
    padding:28px 24px 24px;
    margin-bottom:16px;
    position:relative;
  }
  .status-pill{
    position:absolute;
    top:20px; right:20px;
    display:flex; align-items:center; gap:6px;
    background:rgba(255,255,255,0.08);
    border:1px solid var(--border);
    padding:5px 10px 5px 8px;
    border-radius:20px;
    font-size:11.5px;
    color:var(--text-dim);
    font-weight:500;
  }
  .status-pill .dot{
    width:6px;height:6px;border-radius:50%;
    background:var(--green);
    box-shadow:0 0 6px var(--green);
    animation:pulse 1.8s ease-in-out infinite;
  }
  @keyframes pulse{0%,100%{opacity:1;} 50%{opacity:0.4;}}

  .avatar{
    width:64px; height:64px;
    border-radius:20px;
    background:linear-gradient(135deg,#5b7cff,#c14fff 60%,#ff5fa8);
    display:flex; align-items:center; justify-content:center;
    font-size:26px; font-weight:800;
    color:#fff;
    margin-bottom:16px;
    box-shadow:0 6px 18px rgba(91,124,255,0.35);
  }
  .name{
    font-size:26px;
    font-weight:800;
    letter-spacing:-0.02em;
    margin-bottom:4px;
  }
  .username{
    font-size:14.5px;
    color:var(--blue);
    font-weight:600;
    margin-bottom:2px;
  }
  .location{
    font-size:13.5px;
    color:var(--text-dim);
    display:flex; align-items:center; gap:5px;
    margin-top:6px;
  }

  .chips{
    display:flex; flex-wrap:wrap; gap:8px;
    margin-top:18px;
  }
  .chip{
    font-size:12.5px;
    font-weight:500;
    color:var(--text);
    background:rgba(255,255,255,0.07);
    border:1px solid var(--border);
    padding:6px 12px;
    border-radius:14px;
  }

  .section-label{
    font-size:12px;
    font-weight:600;
    text-transform:uppercase;
    letter-spacing:0.06em;
    color:var(--text-faint);
    margin:22px 4px 8px;
  }

  .list{
    padding:4px;
    margin-bottom:6px;
  }
  .row{
    display:flex;
    align-items:center;
    gap:12px;
    padding:13px 12px;
    border-radius:16px;
    text-decoration:none;
    color:var(--text);
    transition:background 0.18s ease;
  }
  .row:not(:last-child){
    border-bottom:1px solid rgba(255,255,255,0.06);
  }
  .row:hover{
    background:rgba(255,255,255,0.06);
  }
  .row .icon{
    width:34px; height:34px;
    border-radius:10px;
    display:flex; align-items:center; justify-content:center;
    font-size:16px;
    flex-shrink:0;
  }
  .icon.blue{background:linear-gradient(135deg,#3d6bff,#64b5ff);}
  .icon.purple{background:linear-gradient(135deg,#8a3dff,#c14fff);}
  .icon.pink{background:linear-gradient(135deg,#ff3d8a,#ff8fb8);}
  .icon.green{background:linear-gradient(135deg,#1fbf75,#38e07a);}
  .icon.gray{background:linear-gradient(135deg,#4a5568,#6b7688);}

  .row .text{flex:1; min-width:0;}
  .row .title{font-size:14.5px; font-weight:600;}
  .row .sub{font-size:12.5px; color:var(--text-dim); margin-top:1px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;}
  .row .chevron{color:var(--text-faint); font-size:15px;}

  footer{
    text-align:center;
    margin-top:22px;
    font-size:12px;
    color:var(--text-faint);
    padding-bottom:10px;
  }

  @media (prefers-reduced-motion: reduce){
    .orb, .status-pill .dot{animation:none;}
  }
</style>
</head>
<body>

