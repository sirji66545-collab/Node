<!DOCTYPE html>
<html>
<head>
    <title>API Keys - OSINT Hub</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dark-theme.css">
    <link rel="stylesheet" href="/css/responsive.css">
</head>
<body>
    <%- include('partials/sidebar', { currentPage: 'api-keys' }) %>
    <div class="main-content">
        <%- include('partials/topbar', { pageTitle: '🔑 API Keys Management' }) %>
        <div class="content">
            <div class="card">
                <h3>All API Keys</h3>
                <table>
                    <thead>
                        <tr><th>Key</th><th>Name</th><th>Hits</th><th>Status</th><th>Created</th><th>Expires</th></tr>
                    </thead>
                    <tbody>
                        <% if (keys && keys.length > 0) { %>
                            <% keys.forEach(key => { %>
                                <tr>
                                    <td><code><%= key.key %></code></td>
                                    <td><%= key.name %></td>
                                    <td><%= key.hits %></td>
                                    <td><span class="status-<%= key.status %>"><%= key.status %></span></td>
                                    <td><%= key.created_at %></td>
                                    <td><%= key.expires_at || 'Never' %></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="6">No keys found</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <script src="/js/main.js"></script>
    <script src="/js/theme.js"></script>
</body>
</html>
