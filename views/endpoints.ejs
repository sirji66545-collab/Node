<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>API Endpoints - OSINT Hub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .navbar-brand {
            font-weight: bold;
            font-size: 1.5rem;
        }
        .card {
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: transform 0.3s ease;
        }
        .card:hover {
            transform: translateY(-5px);
        }
        .api-card {
            cursor: pointer;
            border-left: 4px solid #667eea;
            margin-bottom: 20px;
        }
        .api-card:hover {
            background: linear-gradient(135deg, #f5f7fa 0%, #e4e8f0 100%);
        }
        .endpoint-url {
            background: #f0f2f5;
            padding: 10px;
            border-radius: 8px;
            font-family: monospace;
            font-size: 14px;
            word-break: break-all;
        }
        .copy-btn {
            cursor: pointer;
            transition: all 0.2s ease;
        }
        .copy-btn:hover {
            transform: scale(1.1);
            color: #28a745;
        }
        .toast-notify {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 9999;
        }
        .badge-api {
            background: linear-gradient(135deg, #667eea, #764ba2);
        }
        .footer {
            background: rgba(0,0,0,0.8);
            color: white;
            padding: 20px 0;
            margin-top: 50px;
        }
        .footer a {
            color: #ffd700;
            text-decoration: none;
        }
        .search-box {
            margin-bottom: 30px;
        }
        .param-badge {
            background: #e9ecef;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-family: monospace;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="fas fa-terminal"></i> OSINT API Hub
            </a>
            <div class="ms-auto">
                <% if (user) { %>
                    <a href="/admin/dashboard" class="btn btn-outline-light me-2">
                        <i class="fas fa-tachometer-alt"></i> Dashboard
                    </a>
                    <a href="/logout" class="btn btn-outline-danger">
                        <i class="fas fa-sign-out-alt"></i> Logout
                    </a>
                <% } else { %>
                    <a href="/login" class="btn btn-outline-light">
                        <i class="fas fa-lock"></i> Admin Login
                    </a>
                <% } %>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="row">
            <div class="col-12 text-center">
                <h1 class="text-white mb-2">
                    <i class="fas fa-plug"></i> API Endpoints
                </h1>
                <p class="text-white-50 mb-4">Click on any API card to copy the endpoint URL</p>
                
                <div class="search-box">
                    <input type="text" id="searchInput" class="form-control form-control-lg" placeholder="🔍 Search APIs..." style="max-width: 500px; margin: 0 auto; border-radius: 50px;">
                </div>
            </div>
        </div>

        <div class="row" id="apisContainer">
            <% apis.forEach(api => { %>
                <div class="col-md-6 col-lg-4 api-item" data-name="<%= api.display_name.toLowerCase() %>" data-endpoint="<%= api.endpoint %>">
                    <div class="card api-card" onclick="copyToClipboard('<%= api.endpoint %>')">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <h5 class="card-title">
                                    <%= api.display_name %>
                                </h5>
                                <i class="fas fa-copy copy-btn text-secondary" title="Click to copy URL"></i>
                            </div>
                            <div class="endpoint-url mt-2">
                                <code><%= api.endpoint %></code>
                            </div>
                            <div class="mt-2">
                                <span class="param-badge">
                                    <i class="fas fa-code-branch"></i> param: <strong><%= api.param_name %></strong>
                                </span>
                                <span class="param-badge ms-2">
                                    <i class="fas fa-chalkboard-user"></i> example: <%= api.param_example %>
                                </span>
                            </div>
                            <p class="card-text mt-2 small text-muted">
                                <%= api.description %>
                            </p>
                            <div class="mt-2">
                                <code class="small bg-light p-1 rounded">
                                    GET <%= api.endpoint %>?key=YOUR_API_KEY&<%= api.param_name %>=<%= api.param_example %>
                                </code>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
        
        <div class="row mt-4">
            <div class="col-12 text-center">
                <div class="alert alert-info">
                    <i class="fas fa-key"></i> <strong>Need an API key?</strong> 
                    <a href="/login" class="alert-link">Login to admin panel</a> to generate your API key.
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Notification -->
    <div class="toast-notify">
        <div id="copyToast" class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="2000">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-check-circle"></i> Copied to clipboard!
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>

    <footer class="footer">
        <div class="container text-center">
            <p>
                <i class="fab fa-telegram"></i> Owner: <%= owner %> | 
                <i class="fas fa-link"></i> Channel: <%= channel %>
            </p>
            <p class="small mb-0">&copy; 2024 OSINT API Hub | All APIs for educational purposes only</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Copy to clipboard function
        function copyToClipboard(endpoint) {
            const fullUrl = window.location.origin + endpoint;
            navigator.clipboard.writeText(fullUrl).then(function() {
                // Show toast notification
                const toast = new bootstrap.Toast(document.getElementById('copyToast'));
                toast.show();
                
                // Visual feedback on clicked card
                event.currentTarget.style.opacity = '0.8';
                setTimeout(() => {
                    event.currentTarget.style.opacity = '1';
                }, 200);
            }).catch(function(err) {
                console.error('Could not copy: ', err);
                alert('Press Ctrl+C to copy: ' + fullUrl);
            });
        }
        
        // Search functionality
        document.getElementById('searchInput').addEventListener('keyup', function() {
            const searchValue = this.value.toLowerCase();
            const items = document.querySelectorAll('.api-item');
            
            items.forEach(item => {
                const name = item.getAttribute('data-name');
                const endpoint = item.getAttribute('data-endpoint');
                
                if (name.includes(searchValue) || endpoint.includes(searchValue)) {
                    item.style.display = '';
                } else {
                    item.style.display = 'none';
                }
            });
        });
        
        // Add tooltip to copy icons
        document.querySelectorAll('.copy-btn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
            });
        });
    </script>
</body>
</html>
