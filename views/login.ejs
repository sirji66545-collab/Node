<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login - OSINT API Hub</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        html, body {
            height: 100%;
            font-family: 'Segoe UI', sans-serif;
        }

        /* Background video */
        .bg-video {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            object-fit: cover;
            z-index: -2;
        }

        .bg-overlay {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.45);
            z-index: -1;
        }

        body {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .login-container {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 20px;
            padding: 2.5rem;
            width: 380px;
            max-width: 90vw;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35);
        }

        h2 {
            text-align: center;
            color: #fff;
            margin-bottom: 1.5rem;
            font-size: 1.8rem;
        }

        .input-group {
            margin-bottom: 1.3rem;
        }

        label {
            display: block;
            margin-bottom: 0.4rem;
            color: #eee;
            font-size: 0.9rem;
        }

        input {
            width: 100%;
            padding: 0.75rem;
            background: rgba(255, 255, 255, 0.12);
            border: 1px solid rgba(255, 255, 255, 0.25);
            color: #fff;
            border-radius: 10px;
            font-size: 1rem;
        }

        input::placeholder {
            color: rgba(255, 255, 255, 0.6);
        }

        input:focus {
            outline: none;
            border-color: #fff;
        }

        button {
            width: 100%;
            padding: 0.8rem;
            background: #fff;
            border: none;
            color: #111;
            font-weight: 600;
            border-radius: 10px;
            cursor: pointer;
            font-size: 1rem;
            margin-top: 0.3rem;
            transition: 0.2s;
        }

        button:hover {
            background: #ddd;
        }

        .error-msg {
            background: rgba(255, 60, 60, 0.2);
            border: 1px solid rgba(255, 80, 80, 0.5);
            border-radius: 10px;
            padding: 0.7rem;
            margin-bottom: 1rem;
            text-align: center;
            color: #ffb3b3;
            font-size: 0.85rem;
        }

        .footer {
            text-align: center;
            margin-top: 1.3rem;
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.7);
        }

        .footer a {
            color: #fff;
            text-decoration: underline;
        }
    </style>
</head>
<body>

    <video class="bg-video" autoplay muted loop playsinline>
        <source src="https://files.catbox.moe/2jv4js.mp4" type="video/mp4">
    </video>
    <div class="bg-overlay"></div>

    <div class="login-container">
        <h2>Admin Login</h2>

        <% if (error) { %>
        <div class="error-msg">
            <% if (error === 'invalid') { %>Invalid username or password
            <% } else if (error === 'missing') { %>Please enter both username and password
            <% } else { %>Login failed. Please try again
            <% } %>
        </div>
        <% } %>

        <form method="POST" action="/login">
            <div class="input-group">
                <label>Username</label>
                <input type="text" name="username" placeholder="Enter your username" required autofocus>
            </div>
            <div class="input-group">
                <label>Password</label>
                <input type="password" name="password" placeholder="Enter your password" required>
            </div>
            <button type="submit">Login</button>
        </form>

        <div class="footer">
            <p>OSINT API Hub | <a href="/">Home</a></p>
        </div>
    </div>

</body>
</html>
