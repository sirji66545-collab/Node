<!DOCTYPE html>
<html>
<head>
    <title>Data Tables - OSINT Hub</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dark-theme.css">
    <link rel="stylesheet" href="/css/responsive.css">
</head>
<body>
    <%- include('partials/sidebar', { currentPage: 'data-tables' }) %>
    <div class="main-content">
        <%- include('partials/topbar', { pageTitle: '📋 Data Tables' }) %>
        <div class="content">
            <div class="card">
                <h3>Transactions / API Calls</h3>
                <table>
                    <thead>
                        <tr><th>ID</th><th>API Key</th><th>Endpoint</th><th>Status</th><th>IP</th><th>Date</th></tr>
                    </thead>
                    <tbody>
                        <% if (data && data.length > 0) { %>
                            <% data.forEach(item => { %>
                                <tr>
                                    <td><%= item.id %></td>
                                    <td><%= item.api_key %></td>
                                    <td><%= item.endpoint %></td>
                                    <td><%= item.status_code %></td>
                                    <td><%= item.ip_address %></td>
                                    <td><%= item.date %></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="6">No data available</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <script src="/js/main.js"></script>
    <script src="/js/theme.js"></script>
</body>
</html>
